# ── Empathy Engine — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in values as needed.
# The service works fully without any API keys (uses gTTS + keyword emotion detection).

# Optional: Enables the HuggingFace transformer model for emotion detection
# (auto-downloaded on first run, ~250 MB). No key needed — just internet access.
# HF_MODEL=j-hartmann/emotion-english-distilroberta-base

# Optional: Google Cloud TTS for SSML-based synthesis (higher quality)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service_account.json

# Optional: ElevenLabs for highly expressive neural voices
# ELEVENLABS_API_KEY=your_key_here
# ELEVENLABS_VOICE_ID=your_voice_id
